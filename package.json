{
  "name": "genly-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sst dev --profile=dev --stage=dev",
    "build": "sst build",
    "test": "sst bind vitest run --profile=dev --stage=dev ",
    "deploy": "sst deploy",
    "deploy-dev": "sst deploy --stage=dev  --profile=dev",
    "deploy-staging": "sst deploy --stage=staging --profile=staging",
    "deploy-prod": "sst deploy --stage=prod --profile=prod",
    "remove": "sst remove",
    "console": "sst console",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tsconfig/node18": "^18.2.2",
    "aws-cdk-lib": "2.246.0",
    "constructs": "10.3.0",
    "sst": "^2.36.7",
    "typescript": "^5.3.2",
    "vitest": "^3.2.6"
  },
  "workspaces": [
    "packages/*"
  ]
}
